## SMTP configuration (adjust with real credentials)
SMTP_HOST=ssl0.ovh.net
SMTP_PORT=465
SMTP_USERNAME=your_email@example.com
SMTP_PASSWORD=your_password_here
SMTP_FROM=your_email@example.com
SMTP_USE_TLS=false
SMTP_USE_SSL=true

## Auth token secret (change to a strong random string)
SECRET_KEY=replace_with_long_random_string

## Clé API partagée pour l'API stateless de calcul risque/performance/rémunération
## (src/api/risque_performance.py), consommée par le site démo indépendant DEMO_RISQUE_PERFORMANCE.
## Générer avec: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
RISQUE_PERFORMANCE_API_KEY=
