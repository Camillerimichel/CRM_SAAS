{"ast":null,"code":"const computeDefaultApiBase=()=>{if(typeof window===\"undefined\"){return\"\";}const{hostname,port,protocol}=window.location;const isDevServer=port===\"3000\";const isLocalHost=hostname===\"localhost\"||hostname===\"127.0.0.1\";if(isDevServer||isLocalHost){const apiHost=hostname===\"localhost\"?\"127.0.0.1\":hostname;return\"\".concat(protocol,\"//\").concat(apiHost,\":8100\");}return\"\".concat(protocol,\"//\").concat(hostname);};export const API_BASE_URL=process.env.REACT_APP_API_BASE_URL||computeDefaultApiBase();","map":{"version":3,"names":["computeDefaultApiBase","window","hostname","port","protocol","location","isDevServer","isLocalHost","apiHost","concat","API_BASE_URL","process","env","REACT_APP_API_BASE_URL"],"sources":["/var/www/CRM_SAAS/frontend/src/config.js"],"sourcesContent":["const computeDefaultApiBase = () => {\n  if (typeof window === \"undefined\") {\n    return \"\";\n  }\n  const { hostname, port, protocol } = window.location;\n  const isDevServer = port === \"3000\";\n  const isLocalHost = hostname === \"localhost\" || hostname === \"127.0.0.1\";\n\n  if (isDevServer || isLocalHost) {\n    const apiHost = hostname === \"localhost\" ? \"127.0.0.1\" : hostname;\n    return `${protocol}//${apiHost}:8100`;\n  }\n\n  return `${protocol}//${hostname}`;\n};\n\nexport const API_BASE_URL =\n  process.env.REACT_APP_API_BASE_URL || computeDefaultApiBase();\n"],"mappings":"AAAA,KAAM,CAAAA,qBAAqB,CAAGA,CAAA,GAAM,CAClC,GAAI,MAAO,CAAAC,MAAM,GAAK,WAAW,CAAE,CACjC,MAAO,EAAE,CACX,CACA,KAAM,CAAEC,QAAQ,CAAEC,IAAI,CAAEC,QAAS,CAAC,CAAGH,MAAM,CAACI,QAAQ,CACpD,KAAM,CAAAC,WAAW,CAAGH,IAAI,GAAK,MAAM,CACnC,KAAM,CAAAI,WAAW,CAAGL,QAAQ,GAAK,WAAW,EAAIA,QAAQ,GAAK,WAAW,CAExE,GAAII,WAAW,EAAIC,WAAW,CAAE,CAC9B,KAAM,CAAAC,OAAO,CAAGN,QAAQ,GAAK,WAAW,CAAG,WAAW,CAAGA,QAAQ,CACjE,SAAAO,MAAA,CAAUL,QAAQ,OAAAK,MAAA,CAAKD,OAAO,UAChC,CAEA,SAAAC,MAAA,CAAUL,QAAQ,OAAAK,MAAA,CAAKP,QAAQ,EACjC,CAAC,CAED,MAAO,MAAM,CAAAQ,YAAY,CACvBC,OAAO,CAACC,GAAG,CAACC,sBAAsB,EAAIb,qBAAqB,CAAC,CA